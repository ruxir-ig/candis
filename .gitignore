# Byte-compiled / optimized / DLL files
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Virtual environments
venv/
.venv/
.venv-embed/
env/

# IDE files
.vscode/
.idea/

# Challenge Datasets (Too large for Git)
data/candidates.jsonl
data/*.jsonl.gz
\[PUB\] India_runs_data_and_ai_challenge.zip

# Output files
output/*
!output/.gitkeep

# Cache files (embeddings, temp data)
cache/*
!cache/.gitkeep
# ...but commit the small offline LLM judgment caches, so the LLM re-rank is
# reproducible without re-running (and re-paying for) the LLM judge. The big
# embeddings cache and the API-key env file stay ignored.
!cache/llm_rerank.jsonl
!cache/llm_labels.jsonl
!cache/llm_expansion.jsonl

# Internal tool folders
.antigravitycli/
.gemini/
